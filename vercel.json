{
  "functions": {
    "app/api/lgu-list/route.ts": {
      "maxDuration": 30
    },
    "app/api/classify/route.ts": {
      "maxDuration": 15
    },
    "app/api/satellite/route.ts": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
